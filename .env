# ============================================================================
# Production Configuration for Temperature API
# ============================================================================
# Copy to .env and customize for your environment
# IMPORTANT: Keep this file secure and never commit to git
# ============================================================================

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root123
POSTGRES_DB=iot_db

# API Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# JWT Secrets (CRITICAL: Use a strong random 32+ character string)
# Generate with: openssl rand -base64 32
# Current key is for development only - CHANGE for production!
JWT_KEY=s8D4mR7pL0qYz3VnK1bW9hFt6aCx2QeRZ5GvHjK0Lw=
JWT_ISSUER=TemperatureApi.Api
JWT_AUDIENCE=TemperatureApi.Client

# Redis Configuration
REDIS_CONNECTION_STRING=redis:6379

# Application Logging
LOG_LEVEL=Information

# Performance Tuning
REQUEST_TIMEOUT_SECONDS=30
DATABASE_COMMAND_TIMEOUT_SECONDS=10

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production:
#
# [ ] Change POSTGRES_PASSWORD to a strong random value
# [ ] Generate a new JWT_KEY: openssl rand -base64 32
# [ ] Set ASPNETCORE_ENVIRONMENT=Production
# [ ] Enable HTTPS/TLS
# [ ] Configure CORS to specific domain
# [ ] Set up monitoring and alerting
# [ ] Enable database backups
# [ ] Configure log aggregation
# [ ] Load test with expected traffic
# [ ] Review and tune resource limits in docker-compose.yml
# [ ] Setup health check monitoring
# ============================================================================
