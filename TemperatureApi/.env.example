# Database Configuration
# Generate password: openssl rand -base64 16
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_CONNECTION_STRING=Host=localhost;Username=postgres;Password=changeme_strong_password_here;Database=iot_db;Port=5432;Pooling=true;Minimum Pool Size=10;Maximum Pool Size=500;Connection Idle Lifetime=600;

# Redis Configuration
REDIS_CONNECTION_STRING=localhost:6379

# JWT Configuration
# Generate with: openssl rand -base64 32
JWT_KEY=changeme_generate_with_openssl_rand_base64_32

# CORS Configuration
# For production, use your actual domain names
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# ASP.NET Environment
ASPNETCORE_ENVIRONMENT=Development
